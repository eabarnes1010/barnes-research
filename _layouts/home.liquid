---
layout: default
---
<!--
  ===================== HERO: clouds banner with title ON the image =========
    PLACEHOLDER: shows a sky gradient until a clouds photo is supplied.
    To use your clouds image: save it to assets/img/hero.jpg (wide, ~1600px+)
    and uncomment the style="" below (keep the same filename).
  ==============================================================================
-->
<section
  class="lab-banner"
  {% comment %}style="background-image: url('{{ '/assets/img/hero.jpg' | relative_url }}');"{% endcomment %}
>
  <div class="lab-banner-content">
    <h1 class="lab-title">Environmental Data Science</h1>
    <a class="lab-sub-logo" href="https://www.bu.edu/" aria-label="Boston University">
      <img
        src="{{ '/assets/img/BOSTON_UNIV_fixed.png' | relative_url }}"
        alt="Boston University"
        class="lab-bu-logo"
        loading="eager"
      >
    </a>
    <p class="lab-tagline">
      AI for Science &middot;&nbsp; Science of AI &nbsp;&middot;&nbsp; Daily-to-decadal prediction<br>
      Human-coupled Earth system futures
    </p>
  </div>
</section>

<!-- ===================== FEATURE CARDS ===================== -->
<div class="lab-features">
  <a class="lab-feature" href="{{ '/research/' | relative_url }}">
    <div class="lab-feature-media lab-feature-media--video">
      <video
        id="lab-feature-video"
        data-start="0.7"
        autoplay
        muted
        playsinline
        preload="metadata"
        poster="{{ '/assets/img/ai-earth-poster.jpg' | relative_url }}"
        aria-label="Animated hand-drawn diagram: Earth data flowing through interpretable AI models into climate-impact predictions."
      >
        <source src="{{ '/assets/video/ai-earth.webm' | relative_url }}" type="video/webm">
        <source src="{{ '/assets/video/ai-earth.mp4' | relative_url }}" type="video/mp4">
      </video>
      <script>
        (function () {
          var v = document.getElementById('lab-feature-video');
          if (!v) return;
          var start = parseFloat(v.dataset.start) || 0; // seconds to skip at start of each loop — tweak data-start
          var seek = function () {
            try {
              v.currentTime = start;
            } catch (e) {}
          };
          v.addEventListener('loadedmetadata', seek);
          v.addEventListener('ended', function () {
            seek();
            v.play();
          });
        })();
      </script>
    </div>
    <h3>Current Projects</h3>
    <p>What we work on.</p>
  </a>
  <a class="lab-feature" href="{{ '/group/' | relative_url }}">
    <div class="lab-feature-media">
      <img src="{{ '/assets/img/people/group_photo_SP26.png' | relative_url }}" alt="The Barnes Research Group" loading="lazy">
    </div>
    <h3>Members</h3>
    <p>Meet the group.</p>
  </a>
  <a class="lab-feature" href="{{ '/publications/' | relative_url }}">
    {%- comment -%}
      Hand-drawn (rough.js) papers-per-year chart, auto-built from
      papers.bib by bin/build_pub_peryear.py (data in _data/pub_peryear.yml).
      Drawn by the scoped script at the bottom of this file.
    {%- endcomment -%}
    <div class="lab-feature-media lab-feature-media--chart">
      {%- if site.data.pub_peryear -%}
        <div
          class="pub-yearchart"
          role="img"
          aria-label="Papers published per year by the group, {{ site.data.pub_peryear.first.year }} to {{ site.data.pub_peryear.last.year }}, drawn in a hand-sketched style."
          data-peryear="{% for d in site.data.pub_peryear %}{{ d.year }}:{{ d.count }}{% unless forloop.last %},{% endunless %}{% endfor %}"
        ></div>
      {%- else -%}
        <i class="fa-solid fa-book-open"></i>
      {%- endif -%}
    </div>
    <h3>Publications</h3>
    <p>Read our papers.</p>
  </a>
</div>

<!-- ===================== INTRO (about.md body) ===================== -->
<div class="lab-intro">
  {{ content }}
</div>

